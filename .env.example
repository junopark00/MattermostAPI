# =============================================================================
# Example Mattermost .env file
# Copy this file to .env and fill in the required values.
# =============================================================================

# Mattermost Server URL
MM_URL=https://mattermost.example.com

# Authentication Method 1: Personal Access Token
MM_TOKEN=your-personal-access-token

# Authentication Method 2: Login Credentials (Username/Email and Password)
# MM_LOGIN_ID=admin@example.com
# MM_PASSWORD=your-password
# MM_MFA_TOKEN=123456

# Optional Settings
# MM_SCHEME=https
# MM_PORT=8065
# MM_TIMEOUT=30
# MM_VERIFY_SSL=true
# MM_DEBUG=false
